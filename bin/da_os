#!/usr/bin/env zsh
#
#
set -u -e -o pipefail

THIS_SCRIPT="$0"

export ORIGIN_DIR="$PWD"

cd "$(dirname "$THIS_SCRIPT")"
cd ..


ORIGIN_PATH="$PATH"
PATH="$PATH:$PWD/base"

case "$*" in
  # doc: CMD -h|--help|help -- Show this message.
  '-h'|"--help")
    cmd="$(basename "$0")"
    grep -E '# +doc:' "$0" | sed 's/#[[:space:]]\+doc:// ; s/CMD/'${cmd}'/'
    exit 0
    ;;

  # doc: CMD paths -- Prints a PATH= string to use as your new PATH.
  paths)
  echo "$ORIGIN_PATH:$PWD/bin:$PWD/$(get_os_name):$PWD/$(get_os_family):$PWD/base"
  exit 0
  ;;
esac

get_script_name() {
  if test -e "$target_os/$1" ; then
    echo "$target_os/$1"
    return 0
  fi

  if test -e "$target_family/$1" ; then
    echo "$target_family/$1"
    return 0
  fi

  if test -e "base/$1" ; then
    echo "base/$1"
    return 0
  fi

  echo "!!! Script not found in $PWD: $1" >&2
  exit 2
}

target_os="$(get_os_name)"
target_family="$(get_os_family)"

# echo "$target_os of $target_family" >&2

script_name="$(get_script_name "$1")"
shift
"$script_name" "$@"

