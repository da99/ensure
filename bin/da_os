#!/usr/bin/env zsh
#
#
set -u -e -o pipefail

THIS_SCRIPT="$0"

export ORIGIN_DIR="$PWD"

cd "$(dirname "$THIS_SCRIPT")"/..
DA_OS_DIR="$PWD"
ORIGIN_PATH="$PATH"

has() {
  command -v "$1" >/dev/null
}

SUB_PATH=""
if has dnf ; then
  SUB_PATH="$SUB_PATH:$DA_OS_DIR/dnf"
fi

if has xbps-install ; then
  SUB_PATH="$SUB_PATH:$DA_OS_DIR/xbps"
fi

if has apk ; then
  SUB_PATH="$SUB_PATH:$DA_OS_DIR/apk"
fi

SUB_PATH="$SUB_PATH:$DA_OS_DIR/base"

case "$*" in
  # doc: CMD --help -- Show this message.
  "--help")
    cmd="$(basename "$0")"
    grep -E '# +doc:' "$0" | sed 's/#[[:space:]]\+doc:// ; s/CMD/'${cmd}'/'
    exit 0
    ;;

  # doc: CMD paths -- Prints a PATH= string to use as your new PATH.
  paths)
  echo "$SUB_PATH"
  exit 0
  ;;
esac

get_script_name() {
  if test -e "$target_os/$1" ; then
    echo "$target_os/$1"
    return 0
  fi

  if test -e "$target_family/$1" ; then
    echo "$target_family/$1"
    return 0
  fi

  if test -e "base/$1" ; then
    echo "base/$1"
    return 0
  fi

  echo "!!! Script not found in $PWD: $1" >&2
  exit 2
}

# target_os="$(get_os_name)"
# target_family="$(get_os_family)"

# echo "$target_os of $target_family" >&2

PATH="$PATH:$SUB_PATH"
"$@"

