#!/usr/bin/env zsh
#
#
set -u -e -o pipefail

if test -e ".env" ; then
  set -a
  source ".env"
  set +a
fi

THIS_SCRIPT="$0"
export ORIGIN_DIR="$PWD"
cd "$(dirname "$THIS_SCRIPT")"/..
export DA_OS_DIR="$PWD"
export ORIGIN_PATH="$PATH"

os_packager="unknown"
os_nickname="unknown"

for NICKNAME in dnf xbps-install apk ; do
  if command -v "$NICKNAME" >/dev/null  ; then
    os_packager="$NICKNAME"
    break
  fi
done

# === Handle special cases:
case "$os_packager" in
  unknown)
    os_nickname="base"
    DA_OS_PATH="$DA_OS_DIR/$os_nickname"
    ;;
  xbps-install)
    os_nickname="xbps"
    DA_OS_PATH="$DA_OS_DIR/$os_nickname:$DA_OS_DIR/base"
    ;;
  *)
    os_nickname="$os_packager"
    DA_OS_PATH="$DA_OS_DIR/$os_nickname:$DA_OS_DIR/base"
    ;;
esac

DA_OS_PATH="$DA_OS_DIR/bin:$DA_OS_PATH"

extract_doc() {
  grep -E '# +doc:' "$1" | sed "s/[#[:space:]]\+doc:/ / ; s/CMD/${cmd}/ ;"
}

find_cmds() {
  find "$1"/ -maxdepth 1 -mindepth 1 -type f -executable -not -name '.*' -and -not -name '_*'
}

case "$*" in
  "--help")
    echo "OS nickname: $os_nickname"
    cmd="--help"
    extract_doc "$0" || :
    case "$os_nickname" in
      base) : ;;
      *)
        cd "$DA_OS_DIR"
        # while read -r FILE_PATH ; do
        #   cmd="$(basename "$FILE_PATH")"
        #   extract_doc "$FILE_PATH"
        # done < <(find_cmds "$os_nickname")

        while read -r SUB_CMD ; do
          if test -x "$os_nickname/$SUB_CMD" ; then
            FILE_PATH="$os_nickname/$SUB_CMD"
          else
            FILE_PATH="base/$SUB_CMD"
          fi
          cmd="$(basename "$FILE_PATH")"
          extract_doc "$FILE_PATH" || { echo "  $SUB_CMD" ; }
        done < <({ find_cmds "base"; find_cmds "$os_nickname"; } | xargs -n 1 basename | sort )
        ;;
    esac
    exit 0
    ;;
esac

# target_os="$(get_os_name)"
# target_family="$(get_os_family)"

# echo "$target_os of $target_family" >&2

export DA_OS_PATH
PATH="$PATH:$DA_OS_PATH"

"$@"

